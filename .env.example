NODE_ENV=development
PORT=4300

# 🔥 Supabase Database Connection (Thay YOUR_XXX bằng thông tin của bạn)
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL='postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require'

# Legacy individual connection params (fallback nếu không dùng DATABASE_URL)
TYPEORM_HOST=aws-0-ap-southeast-1.pooler.supabase.com
TYPEORM_PORT=6543
TYPEORM_USERNAME=postgres.YOUR_PROJECT_ID
TYPEORM_PASSWORD=YOUR_PASSWORD
TYPEORM_DATABASE=postgres
TYPEORM_LOGGING=true

JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRY=10h
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRY=7d
KEY_SECRET=your_encryption_key_here

LIMIT_RQ_PER_SECOND_PER_IP=10
LIMIT_RQ_PER_MINUTE_PER_IP=100

# Zalo Configuration
ZNS_SECRETKEY=YOUR_ZNS_SECRETKEY_HERE
ZNS_APP_ID=YOUR_ZNS_APP_ID_HERE
ZALO_OAUTH_SECRET_KEY=YOUR_ZALO_OAUTH_SECRET_KEY_HERE

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://localhost:4300/auth/google/callback

# Email Configuration
EMAIL_VALIDATE_ACCOUNT=your_email@gmail.com
EMAIL_VALIDATE_PASSWORD="your_app_password_here"
MILLISECOND_OTP_EFFECT=300000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
LINK_UPLOAD=your_upload_folder
