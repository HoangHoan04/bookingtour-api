# Environment
NODE_ENV=development

# Server Configuration
PORT=4300

# Database Configuration (Choose one approach)
# Option 1: Use DATABASE_URL (recommended for Supabase/hosted databases)
DATABASE_URL=postgresql://username:password@host:port/database

# Option 2: Use individual variables (fallback)
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=your_password
TYPEORM_DATABASE=bookingtour_db
TYPEORM_LOGGING=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=10h
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRY=7d
KEY_SECRET=your_key_secret_here

# Rate Limiting
LIMIT_RQ_PER_SECOND_PER_IP=10
LIMIT_RQ_PER_MINUTE_PER_IP=100

# Zalo Configuration
ZNS_SECRETKEY=YOUR_ZNS_SECRETKEY_HERE
ZNS_APP_ID=YOUR_ZNS_APP_ID_HERE
ZALO_OAUTH_SECRET_KEY=YOUR_ZALO_OAUTH_SECRET_KEY_HERE

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://localhost:4300/auth/google/callback

# Email Configuration
EMAIL_VALIDATE_ACCOUNT=your_email@gmail.com
EMAIL_VALIDATE_PASSWORD=your_app_password_here
MILLISECOND_OTP_EFFECT=300000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
LINK_UPLOAD=your_upload_folder
